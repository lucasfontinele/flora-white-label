// Prisma schema — technical foundation only.
//
// Intentionally contains no business models yet. It is the minimum required
// for `prisma generate` to produce a Prisma Client and for the datasource to
// be configured via DATABASE_URL. Real models/migrations are out of scope for
// this boilerplate step.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
