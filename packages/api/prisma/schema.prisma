// Prisma schema.
//
// Models for the initial patient-registration domain slice. `Organization`
// does not exist yet, so `organizationId` is kept as a scalar field for now.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String      @id @default(uuid())
  organizationId         String
  email                  String
  passwordHashed         String
  profile                UserProfile
  guardianId             String?
  patientId              String?
  organizationEmployeeId String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  guardian             Guardian?             @relation("UserGuardian", fields: [guardianId], references: [id])
  patient              Patient?              @relation("UserPatient", fields: [patientId], references: [id])
  organizationEmployee OrganizationEmployee? @relation("UserOrganizationEmployee", fields: [organizationEmployeeId], references: [id])

  @@unique([organizationId, email])
  @@map("users")
}

model Guardian {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  document       String
  birthdate      DateTime
  gender         Gender
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users    User[]    @relation("UserGuardian")
  patients Patient[]

  @@unique([organizationId, document])
  @@map("guardians")
}

model Patient {
  id              String        @id @default(uuid())
  organizationId  String
  guardianId      String?
  name            String
  document        String
  birthdate       DateTime
  gender          Gender
  underPrivileged Boolean       @default(false)
  patientStatus   PatientStatus @default(WAITING_DOCUMENTS)
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  guardian          Guardian?                             @relation(fields: [guardianId], references: [id])
  users             User[]                                @relation("UserPatient")
  assessments       PatientAssessment[]
  documentApprovals OrganizationDocumentPatientApproval[]

  @@unique([organizationId, document])
  @@map("patients")
}

model PatientAssessment {
  id         String    @id @default(uuid())
  patientId  String
  guardianId String
  isApproved Boolean   @default(false)
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("patient_assessments")
}

model SubscriptionPlan {
  id                 String   @id @default(uuid())
  title              String
  description        String?
  priceInCents       Int
  operatorsLimit     Int
  patientsLimit      Int
  unlimitedOperators Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organizations Organization[]

  @@map("subscription_plans")
}

model Address {
  id           String   @id @default(uuid())
  title        String?
  zipcode      String
  street       String
  neighborhood String
  complement   String?
  city         String
  state        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizations Organization[]

  @@map("addresses")
}

model Organization {
  id             String   @id @default(uuid())
  slug           String   @unique
  tradeName      String
  legalName      String
  cnpj           String   @unique
  primaryCnae    String
  secondaryCnaes String[]
  currentPlanId  String
  addressId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  currentPlan       SubscriptionPlan                      @relation(fields: [currentPlanId], references: [id])
  address           Address                               @relation(fields: [addressId], references: [id])
  settings          OrganizationSettings?
  employees         OrganizationEmployee[]
  requiredDocuments OrganizationRequiredDocument[]
  documentApprovals OrganizationDocumentPatientApproval[]

  @@map("organizations")
}

model OrganizationEmployee {
  id             String   @id @default(uuid())
  organizationId String
  fullName       String
  document       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  users        User[]       @relation("UserOrganizationEmployee")

  @@unique([organizationId, document])
  @@map("organizations_employees")
}

model OrganizationSettings {
  id             String   @id @default(uuid())
  organizationId String   @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_settings")
}

model OrganizationRequiredDocument {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  observations   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization                          @relation(fields: [organizationId], references: [id])
  approvals    OrganizationDocumentPatientApproval[]

  @@unique([organizationId, name])
  @@map("organization_required_documents")
}

model OrganizationDocumentPatientApproval {
  id             String                 @id @default(uuid())
  organizationId String
  documentId     String
  patientId      String
  status         DocumentApprovalStatus @default(PENDING)
  rejectedReason String?
  fileName       String?
  mimeType       String?
  size           Int?
  storageKey     String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization                      @relation(fields: [organizationId], references: [id])
  document     OrganizationRequiredDocument      @relation(fields: [documentId], references: [id])
  patient      Patient                           @relation(fields: [patientId], references: [id])
  logs         OrganizationDocumentApprovalLog[]

  @@unique([documentId, patientId])
  @@map("organization_document_patient_approvals")
}

model OrganizationDocumentApprovalLog {
  id                 String   @id @default(uuid())
  action             String
  patientApprovalId  String
  organizationUserId String
  createdAt          DateTime @default(now())

  patientApproval OrganizationDocumentPatientApproval @relation(fields: [patientApprovalId], references: [id])

  @@map("organization_document_approval_logs")
}

enum UserProfile {
  Master
  Organization
  Patient
  Guardian
}

enum Gender {
  M
  F
  O
  NA @map("N/A")
}

enum DocumentApprovalStatus {
  PENDING
  REJECTED
  APPROVED
}

enum PatientStatus {
  WAITING_DOCUMENTS
  WAITING_APPROVAL
  APPROVAL
  REJECTED
}
