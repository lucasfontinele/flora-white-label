generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OperatorLimitType {
  limited
  unlimited
}

enum UserType {
  MASTER
  ORGANIZATION
  STANDARD
}

enum UserRole {
  TUTOR
  PATIENT
  BACKOFFICE
}

enum UserSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum RefreshTokenStatus {
  ACTIVE
  ROTATED
  REVOKED
  EXPIRED
  REUSED
}

enum AuthenticationAuditEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  REFRESH_SUCCESS
  REFRESH_FAILURE
  LOGOUT
  SESSION_REVOKED
  AUTHORIZATION_REJECTED
  REFRESH_REUSE_DETECTED
}

enum PatientType {
  HUMANO
  ANIMAL
}

enum PatientGender {
  MASCULINO
  FEMININO
  OUTRO
  PREFIRO_NAO_INFORMAR
}

enum PatientGuardianRelationship {
  MAE_PAI
  TUTOR
  FILHO
  CUIDADOR
  PROCURADOR
}

enum PetSpecies {
  CANINA
  FELINA
  EQUINA
  AVIARIA
  EXOTICA
  SILVESTRE
  OUTRAS
}

model Address {
  id              String           @id @default(cuid())
  cep             String
  logradouro      String
  number          String
  complement      String?
  neighborhood    String
  city            String
  state           String
  organization    Organization?
  patient         Patient?
  patientGuardian PatientGuardian?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("addresses")
}

model SubscriptionPlan {
  id                String            @id @default(cuid())
  code              String            @unique
  name              String            @unique
  priceInCents      Int
  maxActiveUsers    Int
  operatorLimitType OperatorLimitType
  maxOperators      Int?
  organizations     Organization[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("subscription_plans")
}

model Organization {
  id                    String           @id @default(cuid())
  legalName             String
  tradeName             String
  cnpj                  String           @unique
  foundationDate        DateTime
  primaryCnae           String
  secondaryCnaes        String[]         @default([])
  institutionalEmail    String
  phone                 String?
  whatsapp              String
  site                  String?
  instagram             String?
  facebook              String?
  linkedin              String?
  isActive              Boolean          @default(true)
  addressId             String           @unique
  subscriptionPlanId    String
  createdByMasterUserId String
  users                 User[]
  patients              Patient[]
  address               Address          @relation(fields: [addressId], references: [id], onDelete: Restrict)
  subscriptionPlan      SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([subscriptionPlanId])
  @@map("organizations")
}

model User {
  id               String                     @id @default(cuid())
  email            String                     @unique
  passwordHash     String
  type             UserType
  role             UserRole?
  organizationId   String?
  organization     Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  isActive         Boolean                    @default(true)
  lastLoginAt      DateTime?
  patient          Patient?
  patientGuardians PatientGuardian[]
  sessions         UserSession[]
  auditEvents      AuthenticationAuditEvent[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([organizationId])
  @@map("users")
}

model Patient {
  id             String            @id @default(cuid())
  userId         String?           @unique
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?
  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  fullName       String
  document       String?
  type           PatientType
  birthDate      DateTime?
  nickname       String?
  gender         PatientGender?
  phone          String?
  addressId      String?           @unique
  address        Address?          @relation(fields: [addressId], references: [id], onDelete: SetNull)
  guardians      PatientGuardian[]
  pet            Pet?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([organizationId])
  @@index([document])
  @@index([type])
  @@map("patients")
}

model PatientGuardian {
  id           String                      @id @default(cuid())
  userId       String
  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient                     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fullName     String
  document     String
  rg           String?
  birthDate    DateTime
  phone        String
  relationship PatientGuardianRelationship
  addressId    String?                     @unique
  address      Address?                    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@unique([userId, patientId])
  @@index([patientId])
  @@index([document])
  @@map("patient_guardians")
}

model Pet {
  id        String     @id @default(cuid())
  patientId String     @unique
  patient   Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  species   PetSpecies
  breed     String?    @db.VarChar(100)
  birthDate DateTime?
  diagnosis String?    @db.Text
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([species])
  @@map("pets")
}

model UserSession {
  id            String                     @id @default(cuid())
  userId        String
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        UserSessionStatus          @default(ACTIVE)
  userAgent     String?
  ipAddress     String?
  lastUsedAt    DateTime                   @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?
  refreshTokens RefreshToken[]
  auditEvents   AuthenticationAuditEvent[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("user_sessions")
}

model RefreshToken {
  id                String             @id @default(cuid())
  sessionId         String
  session           UserSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tokenHash         String             @unique
  status            RefreshTokenStatus @default(ACTIVE)
  expiresAt         DateTime
  rotatedAt         DateTime?
  replacedByTokenId String?
  replacedByToken   RefreshToken?      @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacesTokens    RefreshToken[]     @relation("RefreshTokenRotation")
  usedAt            DateTime?
  revokedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuthenticationAuditEvent {
  id           String                       @id @default(cuid())
  userId       String?
  user         User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId    String?
  session      UserSession?                 @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  type         AuthenticationAuditEventType
  emailAttempt String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime                     @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([type])
  @@map("authentication_audit_events")
}
