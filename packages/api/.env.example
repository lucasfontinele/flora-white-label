NODE_ENV=development
HOST=0.0.0.0
PORT=3333
DATABASE_URL="postgresql://flora:flora@localhost:5432/flora?schema=public"
# Exact origins always allowed (optional; subdomains are covered below).
CORS_ALLOWED_ORIGINS=""
# Base domains whose subdomains are allowed (any port). Add client domains here
# as you point them at the app, e.g. "localhost,flora.app,portal.cliente.com.br".
CORS_ALLOWED_ORIGIN_DOMAINS="localhost"
# Cloudflare Turnstile (bot mitigation). Defaults to the "always passes" test
# secret so local dev works out of the box; use the real secret in production.
# Set TURNSTILE_ENABLED=false to fully bypass (offline dev / CI).
TURNSTILE_ENABLED="true"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"
