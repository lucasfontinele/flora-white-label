NEXT_PUBLIC_API_URL="http://localhost:3333"
# Root domain for subdomain tenant resolution (e.g. vida-verde.flora.app).
# Use "localhost" in dev so vida-verde.localhost:3000 resolves the tenant.
NEXT_PUBLIC_ROOT_DOMAIN="localhost"
# Fallback organization used only when no subdomain is present (dev / apex).
NEXT_PUBLIC_ORGANIZATION_ID="org-vida-verde"
# Cloudflare Turnstile site key. Defaults to the "always passes" test key for
# local dev; use the real site key in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
IRON_SESSION_PASSWORD="replace-with-at-least-32-characters-session-secret"
IRON_SESSION_COOKIE_NAME="flora_auth"
